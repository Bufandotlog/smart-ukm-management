[mysqld]
# Basic Resource Limits (Scaled down for 1GB VPS)
max_connections = 30
max_allowed_packet = 16M
table_open_cache = 64
sort_buffer_size = 512K
net_buffer_length = 8K
read_buffer_size = 256K
read_rnd_buffer_size = 512K
myisam_sort_buffer_size = 8M
thread_cache_size = 8
thread_stack = 192K

# Temp Tables
tmp_table_size = 16M
max_heap_table_size = 16M

# Query Cache (Disabled to save memory and avoid lock contention)
query_cache_type = 0
query_cache_size = 0

# InnoDB Memory Optimization (Crucial for Low RAM)
innodb_buffer_pool_size = 64M
innodb_log_buffer_size = 8M
innodb_file_per_table = 1
innodb_buffer_pool_instances = 1
innodb_flush_log_at_trx_commit = 2 # Higher speed, minimal risk of 1-second data loss on crash
innodb_doublewrite = 0             # Disable doublewrite to save Disk I/O (risk of page write failures mitigated by backups)

# InnoDB Thread Optimization
innodb_write_io_threads = 2
innodb_read_io_threads = 2
innodb_purge_threads = 1

# Logs configuration
log_error = /var/log/mysql/error.log
slow_query_log = 0
